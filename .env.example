# Client-facing gateway settings
GATEWAY_API_KEYS=gateway-dev-key
GATEWAY_REQUESTS_PER_MINUTE=60
GATEWAY_UPSTREAM_TIMEOUT=60s
SERVER_PORT=8080

# Primary OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible fallback, for example Ollama, vLLM, DeepSeek, or another vendor
COMPATIBLE_API_KEY=local-development-key
COMPATIBLE_BASE_URL=http://host.docker.internal:11434/v1
COMPATIBLE_MODEL=qwen2.5:7b
